// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("user") // "user" | "admin"
  country       String?   @default("Unknown")
  avatarUrl     String? // Avaturn 3D avatar GLB URL
  avatarConfig  Json? // Custom in-house avatar configuration
  accounts      Account[]
  sessions      Session[]

  // Security Fields
  passwordChangedAt DateTime? @default(now())
  failedAttempts    Int       @default(0)
  lockUntil         DateTime?
  activeSessionId   String?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  scripts      Script[]
  videos       Video[]
  subscription Subscription?
}

model RevokedToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model LoginAttempt {
  id          String   @id @default(cuid())
  ip          String
  email       String?
  count       Int      @default(1)
  lastAttempt DateTime @default(now())

  @@unique([ip, email])
}

model Subscription {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier          String   @default("Free")
  status        String   @default("pending") // active | pending | paused | cancelled | restricted
  paymentStatus String   @default("pending") // paid | pending | failed | refunded
  features      Json     @default("{\"voice\":false,\"video\":false,\"api\":false,\"priority\":false}")
  startDate     DateTime @default(now())
  renewalDate   DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Tier {
  id           String   @id @default(cuid())
  name         String   @unique
  price        Float
  billingCycle String // monthly | annual
  trialDays    Int
  maxUsers     Int
  features     Json // { voice: boolean, video: boolean, api: boolean, priority: boolean }
  quotas       Json // { voiceCharsPerDay: number, videoMinsPerMonth: number, apiCallsPerDay: number, storageMB: number }
  approvalMode String // auto | manual
  color        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  admin     String
  action    String
  target    String
  details   String
  category  String // subscription | user | tier | gate | alert
  createdAt DateTime @default(now())
}

model FeatureGate {
  id        String   @id @default(cuid())
  key       String   @unique // voiceGlobal | videoGlobal | tierMatrix
  value     Json
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Script {
  id        String   @id @default(cuid())
  title     String?
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  videos    Video[]
}

model Video {
  id        String   @id @default(cuid())
  status    String // processing, completed, failed
  url       String?
  scriptId  String?
  script    Script?  @relation(fields: [scriptId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id        String   @id @default(cuid())
  email     String
  createdAt DateTime @default(now())
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  objective String
  message   String
  createdAt DateTime @default(now())
}

// ── Client Portal (NYX × brand partners) ───────────────────────────────────
// `BrandPartner` is an approved client granted access to /portal/[slug].
// Naming reflects NYX's existing landing-page language ("Q3 2026 brand partners").

model BrandPartner {
  id         String             @id @default(cuid())
  email      String             @unique
  clientSlug String             @unique
  clientName String
  approvedAt DateTime           @default(now())
  approvedBy String // admin email who approved
  status     BrandPartnerStatus @default(ACTIVE)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  contentPosts  ContentPost[]
  configuration BrandConfiguration?
  viewers       PortalViewer[]

  @@index([email])
  @@index([clientSlug])
  @@index([status])
}

/// Phase 5 follow-up: read-only guests granted access to a brand's
/// /portal/[clientSlug]. Stored as plain emails (not FKs to User) so an
/// admin can grant access to anyone with a Google account; the User row
/// is created on first sign-in by NextAuth's PrismaAdapter.
model PortalViewer {
  id             String       @id @default(cuid())
  brandPartnerId String
  brandPartner   BrandPartner @relation(fields: [brandPartnerId], references: [id], onDelete: Cascade)
  email          String
  /// Display name shown in the admin list — captured at invite time.
  name           String?
  addedBy        String // admin email
  addedAt        DateTime     @default(now())

  @@unique([brandPartnerId, email])
  @@index([email])
}

// Phase 3 — per-partner content calendar entries
// Phase 4 — added platform, archivedAt, comments back-rel
model ContentPost {
  id             String       @id @default(cuid())
  brandPartnerId String
  brandPartner   BrandPartner @relation(fields: [brandPartnerId], references: [id], onDelete: Cascade)

  title           String
  scheduledDate   DateTime
  contentType     ContentType
  platform        Platform    @default(INSTAGRAM)
  status          PostStatus  @default(IDEA)
  caption         String      @db.Text
  hashtags        String[]
  visualDirection String      @db.Text
  productionNotes String?     @db.Text
  thumbnailUrl    String?
  mediaUrls       String[]    @default([])

  position Int

  archivedAt DateTime?

  comments PostComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandPartnerId])
  @@index([scheduledDate])
  @@index([status])
  @@index([archivedAt])
}

enum ContentType {
  REEL
  CAROUSEL
  STATIC_POST
  STORY
  REEL_STORY
}

enum PostStatus {
  IDEA
  DRAFTING
  NEEDS_APPROVAL
  NEEDS_REVISION
  APPROVED
  POSTED
}

model PendingPartnerRequest {
  id          String               @id @default(cuid())
  email       String               @unique
  name        String? // captured from Google profile when available
  requestedAt DateTime             @default(now())
  status      PendingPartnerStatus @default(PENDING)
  notes       String? // admin notes during review

  @@index([email])
  @@index([status])
}

enum BrandPartnerStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum PendingPartnerStatus {
  PENDING
  REJECTED
}

// ── Phase 4: brand configuration (lifted from src/lib/portal/brands/*.ts)

model BrandConfiguration {
  id             String       @id @default(cuid())
  brandPartnerId String       @unique
  brandPartner   BrandPartner @relation(fields: [brandPartnerId], references: [id], onDelete: Cascade)

  // Display
  brandName String
  tagline   String?
  logoUrl   String?

  // Theming
  primaryColor   String
  secondaryColor String
  accentColor    String?

  // Social
  instagramHandle String?
  tiktokHandle    String?

  // Client meta (Phase 3 legacy fields preserved for the portal adapter)
  clientContactName String?
  clientPhone       String?
  products          String[] @default([])
  operations        String?

  // Campaign
  packageType   PackageType
  campaignStart DateTime
  campaignEnd   DateTime
  platforms     Platform[]

  // Agency block
  agencyContactName  String?
  agencyContactEmail String?

  // Pack B
  packBEnabled       Boolean  @default(false)
  packBTitle         String?
  packBDescription   String?  @db.Text
  packBSourcePostIds String[] @default([])
  packBSourceLabels  String[] @default([])
  packBGoals         String[] @default([])

  // Footer
  confidentialityNote String? @db.Text
  renewalEmail        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PackageType {
  TRIAL
  MONTHLY_RETAINER
  CUSTOM
}

enum Platform {
  INSTAGRAM
  TIKTOK
}

// ── Phase 4: post-level comments (revision requests, approval notes,
//    internal admin notes). authorEmail is plain text, not an FK.

model PostComment {
  id          String      @id @default(cuid())
  postId      String
  post        ContentPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorEmail String
  body        String      @db.Text
  type        CommentType
  createdAt   DateTime    @default(now())

  @@index([postId])
  @@index([createdAt])
}

enum CommentType {
  REVISION_REQUEST
  APPROVAL_NOTE
  INTERNAL_ADMIN
}
